{
  "name": "api-courier",
  "version": "1.0.0",
  "description": "Professional API testing tool built with Electron",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "npm run build && electron . --dev",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "tsc -p tsconfig.renderer.json && cp -r src/renderer/*.html src/renderer/styles src/renderer/js/*.js dist/renderer/ && cp -r src/renderer/js dist/renderer/ || true",
    "watch": "npm run watch:main & npm run watch:preload & npm run watch:renderer",
    "watch:main": "tsc -p tsconfig.main.json -w",
    "watch:preload": "tsc -p tsconfig.preload.json -w",
    "watch:renderer": "tsc -p tsconfig.renderer.json -w",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,json}",
    "prepare": "husky install"
  },
  "keywords": [
    "api",
    "testing",
    "http",
    "electron",
    "typescript"
  ],
  "author": "API Courier Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "electron": "^26.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
