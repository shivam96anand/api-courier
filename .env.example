# .env.example
#
# Copy this file to .env and fill in real values for local development.
# NEVER commit the real .env file — it is listed in .gitignore.
#
# =============================================================================
# Code Signing (macOS Developer ID)
# =============================================================================
#
# Base-64-encoded Developer ID Application certificate (.p12).
# Generate: base64 -i MyCert.p12 | pbcopy
#   Leave blank to build without signing (gatekeeper will block the app).
CSC_LINK=

# Password used to protect the .p12 certificate file.
CSC_KEY_PASSWORD=

# Your Apple Developer Team ID (10 alphanumeric characters).
# Find it at https://developer.apple.com/account → Membership.
APPLE_TEAM_ID=

# =============================================================================
# Notarization (App Store Connect API Key)
# =============================================================================
#
# These allow the build pipeline to submit the signed app to Apple for
# notarization without an Apple ID + password (which require 2FA).
#
# Create a key at: https://appstoreconnect.apple.com/access/api
#   Key ID (short alphanumeric string shown in the table)
APPLE_API_KEY_ID=

#   Issuer UUID shown at the top of the API keys page
APPLE_API_ISSUER=

#   Full contents of the downloaded .p8 file (including -----BEGIN/END----- lines)
#   Either paste the multi-line PEM here, or set it in CI as a multi-line secret.
APPLE_API_KEY=

# =============================================================================
# GitHub Releases Publishing
# =============================================================================
#
# Personal Access Token (or the workflow GITHUB_TOKEN) with "contents: write".
# Required only when running `npm run release` locally to push to GitHub Releases.
GH_TOKEN=

# =============================================================================
# AI / Local LLM (optional)
# =============================================================================
#
# URL of the local OpenAI-compatible LLM server used by the Ask-AI feature.
# Defaults to http://localhost:9999 when not set.
LLM_BASE_URL=http://localhost:9999

# Model name served by the local LLM server.
LLM_MODEL=qwen2.5-7b-instruct
